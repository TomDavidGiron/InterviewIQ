# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection. The database must exist before starting the app.
# Flyway will run migrations automatically on startup.
DB_URL=jdbc:postgresql://localhost:5432/cvoptimizer
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ─── AI Evaluation ───────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# Leave blank to disable AI evaluation — keyword-based scoring is used instead.
OPENAI_API_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# In production, replace with your frontend domain.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── OCR (optional) ──────────────────────────────────────────────────────────
# Path to the Tesseract tessdata directory.
# Leave blank to auto-detect (works on Windows, Mac, and Linux default installs).
# Example (Linux): /usr/share/tesseract-ocr/4.00/tessdata
# Example (Mac):   /opt/homebrew/share/tessdata
# Example (Windows): C:/Program Files/Tesseract-OCR/tessdata
OCR_TESSDATA_PATH=
