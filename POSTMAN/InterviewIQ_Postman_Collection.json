                  "const data = pm.response.json();",
                  "pm.test('status exists', function () { pm.expect(data.status).to.be.a('string'); });",
                  "pm.test('questionIndex and totalQuestions exist', function () {",
                  "  pm.expect(data.questionIndex).to.be.a('number');",
                  "  pm.expect(data.totalQuestions).to.be.a('number');",
                  "});",
                  "pm.test('currentQuestion exists', function () { pm.expect(data.currentQuestion).to.be.an('object'); });",
