  "item": [
    {
      "name": "00 - Setup & Smoke",
      "description": "Basic endpoints to verify the API is up and returning expected shapes.",
      "item": [
        {
          "name": "Get Interview Topics",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Returns available interview topics from the question bank.",
            "url": {
              "raw": "{{baseUrl}}/api/interview/topics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "interview",
                "topics"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json'); });",
                  "const data = pm.response.json();",
                  "pm.test('Topics is an array', function () { pm.expect(data).to.be.an('array'); });",
                  "pm.test('Topics array is not empty', function () { pm.expect(data.length).to.be.above(0); });",
                  "pm.environment.set('detectedTopic', data[0]);"
                ]
              }
            }
          ]
        },
        {
          "name": "RAG Search",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Searches knowledge chunks using the RAG pipeline.",
            "url": {
              "raw": "{{baseUrl}}/api/rag/search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "rag",
                "search"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"{{ragQuery}}\",\n  \"limit\": 3\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json'); });",
                  "const data = pm.response.json();",
                  "pm.test('query field exists', function () { pm.expect(data).to.have.property('query'); });",
                  "pm.test('chunks is an array', function () { pm.expect(data.chunks).to.be.an('array'); });",
                  "pm.test('context is an array', function () { pm.expect(data.context).to.be.an('array'); });",
                  "if (data.chunks.length > 0) {",
                  "  pm.test('first chunk has required fields', function () {",
                  "    const c = data.chunks[0];",
                  "    pm.expect(c).to.have.property('content');",
                  "    pm.expect(c).to.have.property('topic');",
                  "    pm.expect(c).to.have.property('similarity');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Job Scraping",
      "description": "Manual-input endpoints are deterministic and ideal for deep testing. URL scraping is included as optional because it depends on the external website.",
      "item": [
        {
          "name": "Create Manual Job Input",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Creates a manual job description entry and returns it as ScraperResult.",
            "url": {
              "raw": "{{baseUrl}}/api/scrape/manual-input",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "scrape",
                "manual-input"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{manualJobTitle}}\",\n  \"company\": \"{{manualJobCompany}}\",\n  \"location\": \"{{manualJobLocation}}\",\n  \"description\": \"Build and maintain backend APIs with Spring Boot, PostgreSQL, Docker and REST best practices.\",\n  \"requirements\": [\n    \"Java\",\n    \"Spring Boot\",\n    \"SQL\",\n    \"Docker\",\n    \"REST APIs\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json'); });",
                  "const data = pm.response.json();",
                  "pm.test('manual job title matches', function () { pm.expect(data.title).to.eql(pm.variables.replaceIn('{{manualJobTitle}}')); });",
                  "pm.test('requirements is a non-empty array', function () { pm.expect(data.requirements).to.be.an('array').that.is.not.empty; });",
                  "pm.environment.set('latestManualJobTitle', data.title);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Manual Job Inputs",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Fetches all saved manual job descriptions.",
            "url": {
              "raw": "{{baseUrl}}/api/scrape/manual-inputs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "scrape",
                "manual-inputs"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json'); });",
                  "const data = pm.response.json();",
                  "pm.test('manual inputs is an array', function () { pm.expect(data).to.be.an('array'); });",
                  "pm.test('at least one manual input exists', function () { pm.expect(data.length).to.be.above(0); });",
                  "const expectedTitle = pm.environment.get('latestManualJobTitle') || pm.variables.replaceIn('{{manualJobTitle}}');",
                  "pm.test('created manual job can be found in list', function () {",
                  "  const found = data.some(x => x.title === expectedTitle);",
                  "  pm.expect(found).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Scrape Job By URL (Optional)",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Optional external-site test. This may fail if the target page is unavailable or blocks scraping.",
            "url": {
              "raw": "{{baseUrl}}/api/scrape?url={{jobUrl}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "scrape"
              ],
              "query": [
                {
                  "key": "url",
                  "value": "{{jobUrl}}"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 500 depending on external target', function () {",
                  "  pm.expect([200,500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.test('scrape result has basic shape', function () {",
                  "    pm.expect(data).to.have.property('title');",
                  "    pm.expect(data).to.have.property('description');",
                  "    pm.expect(data).to.have.property('requirements');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
