    {
      "name": "03 - Job-Specific Interview Flow",
      "description": "Starts an interview from pasted job text so it is deterministic and does not depend on external scraping.",
      "item": [
        {
          "name": "Start Job-Specific Interview (TEXT payload)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Starts a job-specific interview using pasted job description text.",
            "url": {
              "raw": "{{baseUrl}}/api/interview/job-specific",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "interview",
                "job-specific"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceType\": \"TEXT\",\n  \"payload\": \"We are hiring a Junior Backend Developer. Requirements: Java, Spring Boot, SQL, REST APIs, Docker, Git. Nice to have: AWS and CI/CD.\",\n  \"topic\": \"backend\",\n  \"userId\": \"{{userId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json'); });",
                  "const data = pm.response.json();",
                  "pm.test('job-specific sessionId exists', function () { pm.expect(data.sessionId).to.be.a('string').and.not.empty; });",
                  "pm.test('firstQuestion exists', function () { pm.expect(data.firstQuestion).to.be.an('object'); });",
                  "pm.environment.set('jobSessionId', data.sessionId);",
                  "pm.collectionVariables.set('jobSessionId', data.sessionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Answer Job-Specific Interview Question",
          "request": {
